# Optional: Google Analytics (G-xxx or UA-xxx). Omit to disable tracking.
# NEXT_PUBLIC_GA_ID=

# Contact form (https://resend.com). Omit to build/deploy without email; form returns 503 until set.
# RESEND_API_KEY=
# RESEND_DESTINATION_EMAIL=you@example.com

# Inbound webhook only (advanced). Usually leave unset.
# RESEND_WEBHOOK_SECRET=

# Optional Cloudflare Turnstile for contact form protection.
# If TURNSTILE_SECRET_KEY is set, backend requires a valid token.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
